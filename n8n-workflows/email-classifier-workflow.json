{
  "name": "📧 Email AI Sınıflandırıcı (Email Classifier)",
  "nodes": [
    {
      "parameters": {
        "triggerOn": "newEmail",
        "options": {}
      },
      "id": "email_trigger",
      "name": "Gmail Trigger",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 1,
      "position": [100, 100],
      "credentials": {
        "gmailOAuth2": "gmail_oauth"
      }
    },
    {
      "parameters": {
        "functionCode": "return [\n  {\n    from: $json.from,\n    to: $json.to,\n    subject: $json.subject?.replace(/^(Re:|Fwd:)/i, '').trim() || 'No Subject',\n    body: $json.body?.substring(0, 2000) || '',\n    messageId: $json.id,\n    timestamp: new Date().toISOString()\n  }\n]"
      },
      "id": "prepare_email_data",
      "name": "Email Verisi Hazırla",
      "type": "n8n-nodes-base.functionItem",
      "typeVersion": 1,
      "position": [300, 100]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "model": "gpt-4o-mini",
        "jsonMode": true,
        "messages": [
          {
            "role": "system",
            "content": "Você é um especialista em classificação de emails. Analise o email e retorne um JSON com: { \"category\": \"ACIL_DESTEK|TEKLIF_TALEBI|IHTIYAC_ANALIZI|FIYAT_SORUSTU|SIKAYET_IADE|GENEL_BILGI\", \"priority\": \"low|medium|high|critical\", \"sentiment\": \"negative|neutral|positive\", \"confidence\": 0.0-1.0, \"summary\": \"resumo em 1 linha\", \"topics\": [\"lista\", \"de\", \"palavras\"], \"sla_hours\": número }"
          },
          {
            "role": "user",
            "content": "De: {{$json.from}}\nAssunto: {{$json.subject}}\nCorpo: {{$json.body}}"
          }
        ]
      },
      "id": "ai_classify",
      "name": "GPT-4o OpenAI Sınıflandırma",
      "type": "n8n-nodes-base.openai",
      "typeVersion": 1,
      "position": [500, 100],
      "credentials": {
        "openaiApi": "openai_key"
      }
    },
    {
      "parameters": {
        "functionCode": "const aiResponse = JSON.parse($json.message.content);\nreturn [\n  {\n    ...($json),\n    category: aiResponse.category,\n    priority: aiResponse.priority,\n    sentiment: aiResponse.sentiment,\n    confidence: aiResponse.confidence,\n    summary: aiResponse.summary,\n    topics: aiResponse.topics,\n    sla_hours: aiResponse.sla_hours\n  }\n]"
      },
      "id": "parse_category",
      "name": "Kategori Analiz Sonucu Parse Et",
      "type": "n8n-nodes-base.functionItem",
      "typeVersion": 1,
      "position": [700, 100]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.category}}",
              "operation": "equals",
              "value2": "ACIL_DESTEK"
            },
            {
              "value1": "={{$json.category}}",
              "operation": "equals",
              "value2": "TEKLIF_TALEBI"
            },
            {
              "value1": "={{$json.category}}",
              "operation": "equals",
              "value2": "IHTIYAC_ANALIZI"
            },
            {
              "value1": "={{$json.category}}",
              "operation": "equals",
              "value2": "FIYAT_SORUSTU"
            },
            {
              "value1": "={{$json.category}}",
              "operation": "equals",
              "value2": "SIKAYET_IADE"
            }
          ]
        }
      },
      "id": "category_switch",
      "name": "Kategori Branşı (6 Yol)",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [900, 100]
    },
    {
      "parameters": {
        "url": "http://localhost:5678/webhook/email-urgent-support",
        "requestMethod": "POST",
        "options": {}
      },
      "id": "slack_urgent",
      "name": "🔴 Slack #destek-acil",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [1100, 50]
    },
    {
      "parameters": {
        "url": "http://localhost:4000/api/inbox",
        "requestMethod": "POST",
        "bodyParameters": {
          "source": "gmail",
          "category": "={{$json.category}}",
          "priority": "={{$json.priority}}",
          "ai_summary": "={{$json.summary}}",
          "ai_sentiment": "={{$json.sentiment}}",
          "ai_topics": "={{$json.topics}}",
          "ai_confidence": "={{$json.confidence}}",
          "sla_target": "{{$json.sla_hours}} saat",
          "action_required": true,
          "from": "={{$json.from}}",
          "subject": "={{$json.subject}}",
          "body": "={{$json.body}}"
        }
      },
      "id": "ai_brain_inbox",
      "name": "🧠 AI Beyin'e /api/inbox",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [1100, 150]
    },
    {
      "parameters": {
        "from": "noreply@yourcompany.com",
        "to": "={{$json.from}}",
        "subject": "✅ E-mailiniz alınmıştır - {{$json.category}}",
        "text": "Sayın {{$json.from}},\n\nE-mailiniz başarıyla alınmış ve {{$json.category}} olarak sınıflandırılmıştır.\nEn kısa zamanda size geri dönüş yapacağız.\n\nSLA Süresi: {{$json.sla_hours}} saat\n\nTeşekkür ederiz."
      },
      "id": "auto_reply_email",
      "name": "📧 Otomatik Yanıt Maili",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 1,
      "position": [1100, 250]
    }
  ],
  "connections": {
    "email_trigger": {
      "main": [
        [{"node": "prepare_email_data", "branch": 0}]
      ]
    },
    "prepare_email_data": {
      "main": [
        [{"node": "ai_classify", "branch": 0}]
      ]
    },
    "ai_classify": {
      "main": [
        [{"node": "parse_category", "branch": 0}]
      ]
    },
    "parse_category": {
      "main": [
        [{"node": "category_switch", "branch": 0}]
      ]
    },
    "category_switch": {
      "main": [
        [
          {"node": "slack_urgent", "branch": 0},
          {"node": "ai_brain_inbox", "branch": 0},
          {"node": "auto_reply_email", "branch": 0}
        ]
      ]
    }
  }
}
