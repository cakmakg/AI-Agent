# AI ORCHESTRA - ENVIRONMENT VARIABLES TEMPLATE
# Bu dosyayı '.env' olarak kopyalayın ve kendi API anahtarlarınızı girin.

# Express.js Server Port
PORT=4000

# AWS Bedrock Credentials (LLM Modelleri İçin)
AWS_REGION="eu-central-1" # Kendi bölgenizi yazın (örn: eu-central-1, us-east-1)
AWS_ACCESS_KEY_ID="BURAYA_AWS_ACCESS_KEY_G"
AWS_SECRET_ACCESS_KEY="BURAYA_AWS_SECRET_KEY_"

# Discord Webhook (opsiyonel)
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/BURAYA_WEBHOOK_URL"

# ── Telegram Bot ──
# 1) @BotFather'dan yeni bot yarat → token al
# 2) Bota bir mesaj gönder → @userinfobot ile chat_id öğren
TELEGRAM_BOT_TOKEN="BURAYA_BOT_TOKEN"
TELEGRAM_CHAT_ID="BURAYA_CHAT_ID"

# ── WhatsApp (Twilio Sandbox) ──
# 1) twilio.com → Console → Messaging → WhatsApp Sandbox
# 2) Sandbox numarasına "join <kelime>" gönder (aktivasyon)
TWILIO_ACCOUNT_SID="BURAYA_ACCOUNT_SID"
TWILIO_AUTH_TOKEN="BURAYA_AUTH_TOKEN"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
TWILIO_WHATSAPP_TO="whatsapp:+90XXXXXXXXXX"

# ── Google Sheets CRM ──
# HOT_LEAD'leri otomatik kaydetmek için kullanılır.
# Sheet URL'si: https://docs.google.com/spreadsheets/d/BURAYA_ID/edit
# İlk satıra şu başlıkları ekle: Tarih | Saat | Kaynak | Kimden | Konu | Özet | Thread ID | Durum
# "HOT_LEADS" adında bir sekme (sheet) oluştur.
# Gmail OAuth2 credential'larının Sheets API erişimi de olmalı.
GOOGLE_SHEETS_ID="BURAYA_SPREADSHEET_ID"

# ── n8n Entegrasyonu ──
# n8n'nin "Gidiş Köprüleri" — Node.js buraya POST eder, n8n doğru kanala iletir.
#
# Publisher (onaylanan rapor → Telegram/Slack/Discord/vb.)
N8N_PUBLISH_WEBHOOK="http://localhost:5678/webhook/publish"
#
# Support reply (onaylanan ticket yanıtı → Gmail/Slack/vb.)
N8N_REPLY_WEBHOOK="http://localhost:5678/webhook/reply"
#
# Webhook güvenlik sırrı — n8n ve Node.js aynı değeri kullanır.
# n8n Variables menüsünde: N8N_WEBHOOK_SECRET = bu değer
N8N_WEBHOOK_SECRET=""